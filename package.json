{
  "name": "maps-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist-ssr && node scripts/prerender.mjs",
    "typecheck": "tsc -b",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@turf/area": "^7.3.5",
    "@turf/bbox": "^7.3.5",
    "@turf/difference": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/intersect": "^7.3.5",
    "@turf/length": "^7.3.5",
    "@turf/union": "^7.3.5",
    "lucide-react": "^1.17.0",
    "ol": "^10.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.5.3",
    "react-router": "^7.15.1",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "husky": "^9.1.7",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
